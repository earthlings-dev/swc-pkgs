{
    "name": "@swc/cli",
    "version": "0.8.0",
    "description": "CLI for the swc project",
    "main": "./src/swc/index.ts",
    "scripts": {
        "format:src": "prettier --write src",
        "format:examples": "prettier --write examples",
        "format": "bun run format:src && bun run format:examples",
        "test": "bun test src/swc/__tests__",
        "test:watch": "bun test --watch src/swc/__tests__",
        "test:coverage": "bun test --coverage src/swc/__tests__"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/swc-project/pkgs.git"
    },
    "keywords": [
        "swc",
        "cli",
        "babel",
        "es6",
        "transpile",
        "transpiler",
        "compiler",
        "javascript"
    ],
    "author": "강동윤 <kdy1997.dev@gmail.com>",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/swc-project/pkgs/issues"
    },
    "homepage": "https://github.com/swc-project/pkgs",
    "engines": {
        "bun": ">=1.3.11"
    },
    "bin": {
        "swc": "./src/swc/bin.ts",
        "swcx": "./src/swcx/index.ts",
        "spack": "./src/spack/index.ts"
    },
    "dependencies": {
        "@swc/counter": "workspace:^",
        "@xhmikosr/bin-wrapper": "^13.0.5",
        "commander": "^8.3.0",
        "minimatch": "^9.0.3",
        "piscina": "^4.3.1",
        "semver": "^7.3.8",
        "slash": "3.0.0",
        "source-map": "^0.7.3",
        "tinyglobby": "^0.2.13"
    },
    "devDependencies": {
        "@swc/core": "workspace:*",
        "@swc/types": "workspace:*",
        "@types/node": "catalog:",
        "@types/semver": "^7.3.13",
        "chokidar": "^5.0.0",
        "deepmerge": "^4.2.2",
        "typescript": "catalog:"
    },
    "peerDependencies": {
        "@swc/core": "^1.2.66",
        "chokidar": "^5.0.0"
    },
    "peerDependenciesMeta": {
        "chokidar": {
            "optional": true
        }
    },
    "files": [
        "package.json",
        "src"
    ],
    "types": "./src/swc/index.ts",
    "exports": {
        ".": {
            "bun": "./src/swc/index.ts",
            "default": "./src/swc/index.ts"
        },
        "./package.json": "./package.json"
    }
}
